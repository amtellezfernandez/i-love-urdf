{
  "name": "i-love-urdf",
  "version": "0.1.11",
  "type": "commonjs",
  "packageManager": "pnpm@10.32.1",
  "private": false,
  "description": "Core URDF parsing, validation, transform, mesh, and conversion utilities.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "ilu": "./dist/cli.js",
    "i-love-urdf": "./dist/cli.js"
  },
  "scripts": {
    "build": "node ./scripts/build-package.mjs",
    "check:browser-entry": "node ./scripts/check-browser-entry.mjs",
    "ilu": "node ./scripts/run-cli.mjs",
    "prepare": "node ./scripts/build-package.mjs",
    "setup:xacro": "node ./scripts/run-cli.mjs setup-xacro-runtime",
    "smoke": "node ./scripts/smoke-cli.mjs"
  },
  "dependencies": {
    "jsdom": "^29.0.0"
  },
  "keywords": [
    "urdf",
    "robotics",
    "xacro",
    "mjcf",
    "parser"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/amtellezfernandez/i-love-urdf.git"
  },
  "bugs": {
    "url": "https://github.com/amtellezfernandez/i-love-urdf/issues"
  },
  "homepage": "https://github.com/amtellezfernandez/i-love-urdf",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": "^20.19.6 || ^22.0.0 || ^24.0.0",
    "pnpm": ">=10.32.1 <11"
  },
  "volta": {
    "node": "20.19.6",
    "pnpm": "10.32.1"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./local": {
      "types": "./dist/repository/localRepositoryInspection.d.ts",
      "default": "./dist/repository/localRepositoryInspection.js"
    },
    "./xacro-node": {
      "types": "./dist/xacro/xacroNode.d.ts",
      "default": "./dist/xacro/xacroNode.js"
    },
    "./load-source-node": {
      "types": "./dist/sources/loadSourceNode.d.ts",
      "default": "./dist/sources/loadSourceNode.js"
    },
    "./mesh-node": {
      "types": "./dist/mesh/meshNode.d.ts",
      "default": "./dist/mesh/meshNode.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.mjs",
      "require": "./dist/browser.js",
      "default": "./dist/browser.mjs"
    },
    "./src": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
